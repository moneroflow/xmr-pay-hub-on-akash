# Environment Variables for MoneroFlow

# Transak Fiat On-Ramp Integration
# Get your API key from: https://transak.com/
VITE_TRANSAK_API_KEY=YOUR_TRANSAK_API_KEY_HERE

# Transak Environment
# STAGING = Test mode (free, play money)
# PRODUCTION = Live mode (real transactions, requires verification)
VITE_TRANSAK_ENV=STAGING
